from pydantic import BaseModel
from typing import Optional, Dict, Any
import logging

logger = logging.getLogger(__name__)

class OutlineEnhancementRequest(BaseModel):
    """大纲完善请求"""
    novel_id: UUID
    initial_outline: Optional[Dict[str, Any]] = None
    enhancement_options: Optional[Dict[str, Any]] = None

class OutlineEnhancementResponse(BaseModel):
    """大纲完善响应"""
    novel_id: UUID
    enhancement_result: Dict[str, Any]
    process_log: Dict[str, Any]
    enhanced_at: datetime

