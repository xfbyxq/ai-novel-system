        from core.models.character import Character
        
        # 获取相关数据
        world_query = select(WorldSetting).where(WorldSetting.novel_id == novel_id)
        world_result = await db.execute(world_query)
        world_setting = world_result.scalar_one_or_none()
        
        character_query = select(Character).where(Character.novel_id == novel_id)
        character_result = await db.execute(character_query)
        characters = character_result.scalars().all()
        
        # 执行评估
        evaluator = OutlineQualityEvaluator()
        quality_score = await evaluator.evaluate_outline_comprehensively(
            outline=model_to_dict(plot_outline),
            world_setting=model_to_dict(world_setting) if world_setting else {},
            characters=[model_to_dict(char) for char in characters] if characters else []
        )
        
        return OutlineQualityReport(
            overall_score=quality_score.overall_score,
            dimension_scores=quality_score.dimension_scores,
            strengths=quality_score.strengths,
            weaknesses=quality_score.weaknesses,
            improvement_suggestions=[
                {
                    "type": suggestion.type,
                    "priority": suggestion.priority,
                    "description": suggestion.description,
                    "details": suggestion.details
                }
                for suggestion in quality_score.improvement_suggestions
            ]
        )
        
    except Exception as e:
        logger.error(f"质量评估失败：{e}")
        raise HTTPException(
            status_code=500,
            detail=f"质量评估失败：{str(e)}"
        )


@router.post("/outline/enhance-preview", response_model=EnhancementPreviewResponse)
async def enhance_outline_preview(
    novel_id: UUID,
    options: EnhancementOptions = EnhancementOptions(),
    db: AsyncSession = Depends(get_db),
):
    """
    大纲智能完善预览（不修改数据库）
    
    提供优化前后的对比结果，供用户决定是否应用。
    不会直接修改数据库中的大纲内容。
    """
    import time
    import logging
    from agents.crew_manager import NovelCrewManager
    
    logger = logging.getLogger(__name__)
    start_time = time.time()
    
    # 验证小说是否存在
    novel_query = select(Novel).where(Novel.id == novel_id)
    novel_result = await db.execute(novel_query)
    novel = novel_result.scalar_one_or_none()
    
    if not novel:
        raise HTTPException(status_code=404, detail=f"小说 {novel_id} 未找到")
    
    # 获取大纲
    outline_query = select(PlotOutline).where(PlotOutline.novel_id == novel_id)
    outline_result = await db.execute(outline_query)
    plot_outline = outline_result.scalar_one_or_none()
    
    if not plot_outline:
        raise HTTPException(
            status_code=404,
            detail=f"小说 {novel_id} 的情节大纲未找到"
        )
    
    try:
        # 准备小说数据
        from core.models.character import Character
        
        world_query = select(WorldSetting).where(WorldSetting.novel_id == novel_id)
        world_result = await db.execute(world_query)
        world_setting = world_result.scalar_one_or_none()
        
        character_query = select(Character).where(Character.novel_id == novel_id)
        character_result = await db.execute(character_query)
        characters = character_result.scalars().all()
        
        novel_data = {
            "title": novel.title,
            "genre": novel.genre,
            "synopsis": novel.synopsis,
            "world_setting": model_to_dict(world_setting),
            "characters": [model_to_dict(char) for char in characters] if characters else []
        }
        
        initial_outline = model_to_dict(plot_outline)
        
        # 执行完善流程但不更新数据库
        crew_manager = NovelCrewManager()
        enhancement_result = await crew_manager.run_outline_enhancement_phase(
            novel_data=novel_data,
            initial_outline=initial_outline,
            team_context={"novel_id": str(novel_id)}
        )
        
        # 计算质量对比
        from agents.outline_quality_evaluator import OutlineQualityEvaluator
        
        evaluator = OutlineQualityEvaluator()
        original_quality = await evaluator.evaluate_outline_comprehensively(
            outline=model_to_dict(plot_outline),
            world_setting=model_to_dict(world_setting),
            characters=[model_to_dict(char) for char in characters] if characters else []
        )
        
        enhanced_quality = await evaluator.evaluate_outline_comprehensively(
            outline=enhancement_result["enhancement_result"]["enhanced_outline"],
            world_setting=model_to_dict(world_setting),
            characters=[model_to_dict(char) for char in characters] if characters else []
        )
        
        processing_time = time.time() - start_time
        
        # 估算成本（这里可以根据实际使用的token数量计算）
        cost_estimate = 0.0  # 实际实现中应该基于token使用量计算
        
        return EnhancementPreviewResponse(
            original_outline=initial_outline,
            enhanced_outline=enhancement_result["enhancement_result"]["enhanced_outline"],
            quality_comparison={
                "original_score": original_quality.overall_score,
                "enhanced_score": enhanced_quality.overall_score,
                "improvement": enhanced_quality.overall_score - original_quality.overall_score,
                "dimension_improvements": {
                    dim: enhanced_quality.dimension_scores[dim] - original_quality.dimension_scores[dim]
                    for dim in original_quality.dimension_scores.keys()
                }
            },
            improvements_made=enhancement_result["enhancement_result"].get("improvements_made", []),
            processing_time=processing_time,
            cost_estimate=cost_estimate
        )
        
    except Exception as e:
        logger.error(f"大纲完善预览失败：{e}")
        raise HTTPException(status_code=500, detail=f"完善失败：{str(e)}")
