def model_to_dict(model):
    """将SQLAlchemy模型转换为字典"""
    if model is None:
        return None
    
    # 处理不同类型的模型
    if hasattr(model, '__table__'):
        result = {}
        for column in model.__table__.columns:
            value = getattr(model, column.name)
            if hasattr(value, 'isoformat'):
                result[column.name] = value.isoformat()
            elif isinstance(value, uuid.UUID):
    else:
        return model


    else:
        return model
    from core.models.character import Character
    
    # 获取世界观设定
    world_query = select(WorldSetting).where(WorldSetting.novel_id == novel_id)
    world_result = await db.execute(world_query)
    world_setting = world_result.scalar_one_or_none()
    
    # 获取角色列表
    character_query = select(Character).where(Character.novel_id == novel_id)
    character_result = await db.execute(character_query)
    characters = character_result.scalars().all()
    
    # 准备小说数据
    novel_data = {
        "novel_id": str(novel_id),
        "novel_title": novel.title,
        "world_setting": model_to_dict(world_setting) if world_setting else {},
        "characters": [model_to_dict(char) for char in characters] if characters else []
    }
    
    # 如果没有提供初始大纲，则从数据库获取
    if not request.initial_outline:
        outline_query = select(PlotOutline).where(PlotOutline.novel_id == novel_id)
        outline_result = await db.execute(outline_query)
        existing_outline = outline_result.scalar_one_or_none()
        
        if not existing_outline:
            raise HTTPException(
                status_code=404,
                detail=f"小说 {novel_id} 未找到现有大纲"
            )
        
        initial_outline = existing_outline.to_dict()
    else:
        initial_outline = request.initial_outline
    
    # 调用多Agent大纲完善流程
    try:
        # 导入必要的组件
        from agents.crew_manager import NovelCrewManager
        from agents.team_context import NovelTeamContext
        from llm.qwen_client import QwenClient
        from llm.cost_tracker import CostTracker
        
        # 初始化组件
        qwen_client = QwenClient()
        cost_tracker = CostTracker()
        crew_manager = NovelCrewManager(qwen_client, cost_tracker)
        team_context = NovelTeamContext(str(novel_id), novel.title)
        
        # 执行大纲完善
        enhancement_result = await crew_manager.run_outline_enhancement_phase(
            novel_data=novel_data,
            initial_outline=initial_outline,
            team_context=team_context
        )
        
        # 更新数据库中的大纲（如果需要）
        if request.enhancement_options and request.enhancement_options.get("update_database", False):
            outline_query = select(PlotOutline).where(PlotOutline.novel_id == novel_id)
            outline_result = await db.execute(outline_query)
            plot_outline = outline_result.scalar_one_or_none()
            
            if plot_outline:
                # 更新大纲内容
                enhanced_outline = enhancement_result["enhancement_result"]["enhanced_outline"]
                plot_outline.main_plot = enhanced_outline.get("main_plot", plot_outline.main_plot)
                plot_outline.volumes = enhanced_outline.get("volumes", plot_outline.volumes)
                plot_outline.sub_plots = enhanced_outline.get("sub_plots", plot_outline.sub_plots)
                plot_outline.key_turning_points = enhanced_outline.get("key_turning_points", plot_outline.key_turning_points)
                
                await db.commit()
                await db.refresh(plot_outline)
        
        return OutlineEnhancementResponse(
            novel_id=novel_id,
            enhancement_result=enhancement_result,
            process_log={
                "started_at": datetime.now(),
                "completed_at": datetime.now(),
                "steps_executed": ["consistency_check", "collaborative_review", "iterative_optimization"]
            },
            enhanced_at=datetime.now()
        )
        
    except Exception as e:
        logger.error(f"大纲完善过程失败：{e}")
        raise HTTPException(
            status_code=500,
            detail=f"大纲完善失败：{str(e)}"
        )

