# LLM Configuration
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_MODEL=qwen-plus

# Database
DATABASE_URL=postgresql+asyncpg://novel_user:novel_pass@localhost:5432/novel_system
DATABASE_URL_SYNC=postgresql://novel_user:novel_pass@localhost:5432/novel_system

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
